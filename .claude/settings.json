{
  "permissions": {
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm format --write ${file} 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "pnpm lint --fix ${file} 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_FLOW_V3_ENABLED": "true",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  }
}
